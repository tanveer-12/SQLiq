# Option B: Ollama on Colab via ngrok (paste the ngrok URL)
SQLIQ_API_BASE=https://abc123.ngrok-free.app/v1
SQLIQ_API_KEY=ollama
SQLIQ_MODEL=qwen2.5-coder:14b

# ── App settings ─────────────────────────────────────────────────────────────
# Generate a key: POST http://localhost:8000/v1/keys/generate
# Then set it here AND in AGENTSTATE_API_KEYS so the server accepts it.
AGENTSTATE_API_KEYS=dev-key-123
SQLIQ_DB_PATH=sqliq.db
SQLIQ_MAX_RETRIES=3
SQLIQ_HOST=0.0.0.0
SQLIQ_PORT=8000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Must match one of the keys in AGENTSTATE_API_KEYS above.
# Used by the live trace panel to authenticate the SSE stream.
VITE_AGENTSTATE_API_KEY=dev-key-123